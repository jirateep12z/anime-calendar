{
  "name": "anime-calendar",
  "description": "A personal seven-day anime broadcast calendar powered directly by the AniList GraphQL API and localized to Asia/Bangkok.",
  "author": "@jirateep12z",
  "license": "MIT",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "predev": "npm run build:service-worker",
    "dev": "next dev --turbopack",
    "prebuild": "npm run build:service-worker",
    "build": "next build --turbopack",
    "build:service-worker": "node scripts/build-service-worker.mjs",
    "start": "next start",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "lint": "eslint \"{app,pages,components,lib,src}/**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "lint:fix": "eslint \"{app,pages,components,lib,src}/**/*.{js,jsx,ts,tsx,json,css,md}\" --fix",
    "format": "prettier --write \"{app,pages,components,lib,src}/**/*.{js,jsx,ts,tsx,json,css,md}\""
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
