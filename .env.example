# Public application origin
NEXT_PUBLIC_SITE_URL=https://anime-calendar.example.com

# Supabase server credentials
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key

# Notification schedule authorization
NOTIFICATION_CRON_SECRET=replace-with-64-character-random-hex-secret

# Public key produced by scripts/generate-vapid-keys.mjs
NEXT_PUBLIC_VAPID_PUBLIC_KEY=replace-with-generated-vapid-public-key
