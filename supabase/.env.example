# Supabase Edge Function runtime
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key

# Must match the notification_edge_secret value stored in Supabase Vault
NOTIFICATION_EDGE_SECRET=replace-with-64-character-random-hex-secret

# Both values are produced by scripts/generate-vapid-keys.mjs
VAPID_KEYS_JSON={"publicKey":{},"privateKey":{}}
VAPID_SUBJECT=mailto:admin@example.com
